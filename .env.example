# ============================================================
# MiniPaaS — copy this file to ".env" and fill in real values
#   cp .env.example .env
# ============================================================
# Never commit .env (it is listed in .gitignore).

# ----- Database (PostgreSQL / Neon / RDS) -----
# Option A — full JDBC URL (recommended for Neon):
SPRING_DATASOURCE_URL=jdbc:postgresql://HOST:5432/DB_NAME?sslmode=require
SPRING_DATASOURCE_USERNAME=your_db_user
SPRING_DATASOURCE_PASSWORD=your_db_password

# Option B — split vars (docker-compose local postgres uses these + overrides in compose):
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=minipaas
# DB_USER=minipaas
# DB_PASSWORD=minipaas

# ----- Auth -----
JWT_SECRET=change-me-to-a-long-random-string

# ----- Kubernetes / K3s (Control Plane reaches API via Tailscale) -----
KUBECONFIG=/etc/rancher/k3s/k3s.yaml
K8S_MOCK=true

# ----- Container registry (GHCR) -----
GHCR_USER=your-github-username
GHCR_TOKEN=ghp_or_fine_grained_pat_with_write_packages

# ----- Public URL for deployed apps -----
# Custom domain (Traefik Host + optional Cloudflare DNS):
DEPLOYMENT_DOMAIN=
# Public IPv4 that serves Traefik / your ingress (also used for Cloudflare A record):
DEPLOYMENT_K3S_IP=127.0.0.1
# URL scheme returned to users: http (nip.io dev) or https (Cloudflare proxy)
DEPLOYMENT_URL_SCHEME=http

# Legacy alias — used as fallback when DEPLOYMENT_K3S_IP is empty (nip.io mode):
# MASTER_IP=127.0.0.1

# ----- Cloudflare DNS (optional) -----
CLOUDFLARE_DNS_ENABLED=false
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
# Orange cloud only for a public ingress IP. Tailscale 100.x / private: use false (backend forces DNS-only for those ranges).
CLOUDFLARE_PROXIED=true

# ----- Build strategy: kaniko (in-cluster) or github (repository_dispatch) -----
APP_BUILD_STRATEGY=kaniko
# Repo that hosts .github/workflows listening for repository_dispatch (owner/name):
GITHUB_DISPATCH_REPO=your-org/your-control-plane-repo

# ----- Frontend (docker-compose / Vite) -----
VITE_API_URL=http://localhost:8080
# Dev server proxy: máy local dùng 127.0.0.1:8080; docker-compose set http://backend:8080
VITE_PROXY_TARGET=http://127.0.0.1:8080
